# Caddy reverse proxy with automatic HTTPS for the leaderboard API.
# DOMAIN and ACME_EMAIL come from the environment (see docker-compose.prod.yml).

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip

	# /metrics is for the internal Prometheus scrape only — never expose it
	# publicly through the proxy.
	@metrics path /metrics
	respond @metrics 403

	reverse_proxy leaderboardd:8080
}
