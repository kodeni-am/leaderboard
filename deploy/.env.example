# Copy to deploy/.env and fill in. Used by docker-compose.prod.yml.

# Domain Caddy obtains a TLS certificate for. Use "localhost" for a local trial.
DOMAIN=leaderboard.example.com

# Email for Let's Encrypt expiry notices (optional but recommended).
ACME_EMAIL=you@example.com

# Public origin used in account email links and cookies. Behind TLS this is
# https://$DOMAIN.
PUBLIC_URL=https://leaderboard.example.com

# Set true when served over HTTPS so session cookies get the Secure flag.
SECURE_COOKIES=true

# SMTP for account verification / password-reset emails (required for signups).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=change-me
SMTP_FROM=no-reply@example.com

# Optional: enables HMAC-signed submission verification when non-empty.
SIGNING_SECRET=

# Number of ingest stream partitions (set once; changing it rehashes routing).
INGEST_PARTITIONS=16

# How long completed time-windows are retained in the cache before the reaper
# expires them.
LB_REAPER_RETAIN=168h

# Grafana admin password (Grafana is bound to 127.0.0.1:3000; tunnel to reach
# it, e.g. ssh -L 3000:localhost:3000 user@host).
GRAFANA_ADMIN_PASSWORD=change-me
