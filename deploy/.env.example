# Copy to deploy/.env and fill in. Used by docker-compose.prod.yml.

# Domain Caddy obtains a TLS certificate for. Use "localhost" for a local trial.
DOMAIN=leaderboard.example.com

# Email for Let's Encrypt expiry notices (optional but recommended).
ACME_EMAIL=you@example.com

# Required: token for the admin POST /v1/apps endpoint. Generate a strong value:
#   openssl rand -hex 32
ADMIN_TOKEN=change-me

# Optional: enables HMAC-signed submission verification when non-empty.
SIGNING_SECRET=

# Number of ingest stream partitions (set once; changing it rehashes routing).
INGEST_PARTITIONS=16

# How long completed time-windows are retained in the cache before the reaper
# expires them.
LB_REAPER_RETAIN=168h
